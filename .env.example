# Local development values. Production env is set by Cloud Run at deploy
# time (see docs/DEPLOY.md). Never commit real secrets here.
PORT=4000
APP_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me
ADMIN_EMAIL=admin@banghub.kr
ADMIN_PASSWORD=change-me
FIRESTORE_PROJECT_ID=banghub-english-local
FIRESTORE_EMULATOR_HOST=127.0.0.1:9080
USE_FIRESTORE_EMULATOR=true
GOOGLE_TTS_ENABLED=false
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_LANGUAGE=en-US
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
